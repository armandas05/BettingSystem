@page "/Admin/Dashboard"
@model BettingSystem.Pages.DashboardModel
@{
}

<style>

    .sidenav {
        height: 100%;
        width: 200px;
        position: fixed;
        z-index: 1;
        top: 0;
        left: 0;
        background-color: #111;
        overflow-x: hidden;
    }


        .sidenav a {
            color: white;
            padding: 16px;
            text-decoration: none;
            display: block;
        }

            .sidenav a:hover {
                background-color: #ddd;
                color: black;
            }

        
    .content {
        margin-left: 200px;
        padding-left: 20px;
        margin-top: 50px;
    }



    table {
        width: 100%;
        border-collapse: collapse;
        background-color: #1e1e2f;
        color: white;
        border-radius: 10px;
        overflow: hidden;
        
    }

    thead {
        background-color: #2a2a3d;
    }

    th, td {
        padding: 12px 15px;
        text-align: left;
    }

    th {
        cursor: pointer;
        user-select: none;
    }

        th:hover {
            background-color: #3a3a55;
        }

    tbody tr {
        border-bottom: 1px solid #2f2f44;
        transition: 0.2s;
    }

        tbody tr:hover {
            background-color: #2a2a3d;
        }

    #pagination {
        margin-top: 15px;
        display: flex;
        gap: 8px;
    }

    #pagination button {
        padding: 6px 12px;
        background-color: #2a2a3d;
        border: none;
        color: white;
        cursor: pointer;
        border-radius: 6px;
    }

    #pagination button:hover {
        background-color: #3a3a55;
    }
    
    #pagination button.active {
        background-color: #00c2ff;
        color: black;
    }

</style>

<body>

    <div class="sidenav">
        <a onclick="loadPage('DashboardPartial')">Dashboard</a>
         <a onclick="loadPage('UsersPartial')">Users</a>
        <a onclick="loadPage('PaymentsPartial')">Payments</a>


    </div>

    <div id="content" class="content">
        

        <h2>Prideti prie user saraso:
            <ul>
                <li>View</li>
                <li>Block</li>
                <li>Delete DONE</li>
            </ul>  
        </h2>

        <h2>Prideti search pagal:
            <ul>
                <li>user id DONE</li>
                <li>varda arba pavarde DONE</li>
            </ul>
        </h2>

        <h2>Prideti order by:
            <ul>
                <li>Date created done</li>
                <li>Balance done </li>
                <li>Total deposited done</li>
                <li>Games played done</li>
                <li>Blocked players done </li>
            </ul>

        </h2>



    </div>


</body>



<script src="/js/admin.js"></script>


