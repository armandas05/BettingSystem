@page "/Admin/Dashboard"
@model BettingSystem.Pages.DashboardModel
@{
    ViewData["Theme"] = "theme-default";
}

<body>
    <div class="animated-bg">
        <span></span>
        <span></span>
        <span></span>
    </div>

    <div id="content" class="content">

        <h1 class="admin-title">Admin Dashboard</h1>
        <p class="admin-subtitle">Manage platform data and monitor activity</p>

        <div class="admin-grid">

            <div class="admin-card" onclick="loadPage('AnalyticsPartial')">
                <div class="card-icon">📊</div>
                <h3>Analytics</h3>
                <p>View platform stats, charts and performance</p>
            </div>

            <div class="admin-card" onclick="loadPage('UsersPartial')">
                <div class="card-icon">👤</div>
                <h3>Users</h3>
                <p>Manage users, roles and balances</p>
            </div>

            <div class="admin-card" onclick="loadPage('PaymentsPartial')">
                <div class="card-icon">💳</div>
                <h3>Payments</h3>
                <p>Track deposits, withdrawals and transactions</p>
            </div>

            <div class="admin-card" onclick="loadPage('GameHistoryPartial')">
                <div class="card-icon">🎮</div>
                <h3>Game History</h3>
                <p>Inspect bets, results and game logs</p>
            </div>

        </div>

    </div>


</body>


<link rel="stylesheet" href="~/css/admin.css" />
<script src="~/js/admin.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>


