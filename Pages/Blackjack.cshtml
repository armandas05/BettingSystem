@page "/Games/Blackjack"
@model BettingSystem.Pages.BlackjackModel
@{
    ViewData["Theme"] = "theme-blackjack";
}


<div class="blackjack-table text-center">

    <h1>Blackjack</h1>

    <div id="bet-container" style="display:flex; justify-content:center; align-items:center; gap:10px;">
        <input type="number" id="bet-number" min="1" step="1" placeholder="Bet amount"/>
        <button id="startGame">Start Game</button>
    </div>

    <div id="bet-error" style="color:red;"></div>

    <div id="game-area">
        <h3>Dealer</h3>
        <div class="score" id="dealer-score"></div>
        <div id="dealer-hand" class="hand"></div>

        <h3>Player</h3>
        <div class="score" id="player-score"></div>
        <div id="player-hand" class="hand"></div>
    </div>

    <div>
        <button id="hit">Hit</button>
        <button id="stand">Stand</button>
        <button id="restart">Restart</button>
    </div>

    <div id="game-status"></div>
</div>



<div class="rules-container">

    <h2>Rules</h2>

    <button id="toggleRulesBtn" onclick="toggleRules()">
        📘 Show Rules
    </button>

    <div id="rulesContent" class="rules-hidden">

        <div class="rule">
            <h4>🎯 Goal</h4>
            <p>Reach 21 or get closer to 21 than the dealer without going over.</p>
        </div>

        <div class="rule">
            <h4>🃏 Card Values</h4>
            <ul>
                <li>Number cards = face value</li>
                <li>J, Q, K = 10</li>
                <li>Ace = 1 or 11 (automatically adjusted)</li>
            </ul>
        </div>

        <div class="rule">
            <h4>🎮 Gameplay</h4>
            <ul>
                <li>You start with 2 cards</li>
                <li>Dealer has 1 visible and 1 hidden card</li>
                <li>Hit = take another card</li>
                <li>Stand = keep your hand</li>
            </ul>
        </div>

        <div class="rule">
            <h4>🏆 Winning</h4>
            <ul>
                <li>Closer to 21 than dealer → Win</li>
                <li>Go over 21 → Lose (Bust)</li>
                <li>Same score → Draw</li>
            </ul>
        </div>

    </div>
</div>


<link rel="stylesheet" href="~/css/blackjack.css" />
<script src="~/js/blackjack.js"></script>
<script src="~/js/navbar.js"></script>