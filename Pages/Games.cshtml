@page
@model BettingSystem.Pages.GamesModel
@{
    ViewData["Theme"] = "theme-default";
}


<body>
    <div class="animated-bg">
        <span></span>
        <span></span>
        <span></span>
    </div>


    <div class="games-container">

        <h1 class="games-title">🎮 Games</h1>
        <p class="games-subtitle">Choose your game and start winning</p>

        <div class="games-grid">

            <a href="/Games/Blackjack" class="game-card">
                <img src="images/blackjack.jpg" />
                <div class="overlay">
                    <h3>Blackjack</h3>
                    <p>Beat the dealer. Get as close to 21 as possible.</p>
                    <span class="cta">Play now →</span>
                </div>
            </a>

            <a href="/Games/Dices" class="game-card">
                <img src="images/dices.jpg" />
                <div class="overlay">
                    <h3>Dices</h3>
                    <p>Test your luck. Predict the roll and win big.</p>
                    <span class="cta">Play now →</span>
                </div>
            </a>

            <div class="game-card disabled">
                <img src="images/highlow.jpg" />
                <div class="overlay">
                    <h3>High / Low</h3>
                    <p>One card. One decision. Higher or lower?</p>
                    <span class="cta disabled-text">Coming soon</span>
                </div>
            </div>

            <div class="game-card disabled">
                <img src="images/roulette.jpg" />
                <div class="overlay">
                    <h3>Roulette</h3>
                    <p>Classic casino wheel. Red or black?</p>
                    <span class="cta disabled-text">Coming soon</span>
                </div>
            </div>

        </div>

    </div>
</body>

<link rel="stylesheet" href="~/css/games.css" />
<script src="~/js/games.js"></script>